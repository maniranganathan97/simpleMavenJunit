pipeline {
    agent any

    stages {
        stage('Build Java Application') {
            steps {
                // Use a Maven Docker image as a temporary agent to build the project
                script {
                    docker.image('maven:3.8.1-openjdk-17').inside {
                        sh 'mvn clean install -DskipTests'
                    }
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    // Build the Docker image using the Dockerfile in the current directory
                    def appImage = docker.build("manir1389/devops-training-java:${env.BUILD_NUMBER}")
                    // Optionally, you can run tests inside a container spun up from this image
                    // appImage.inside {
                    //     sh 'mvn test'
                    // }
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                script {
                    // Use withRegistry to push the image to Docker Hub using stored credentials
                    withCredentials([usernamePassword(credentialsId: 'docker-hub-credentials', passwordVariable: 'DOCKER_PASS', usernameVariable: 'DOCKER_USER')]) {
                        sh "docker login -u ${env.DOCKER_USER} -p ${env.DOCKER_PASS}"
                        sh "docker push manir1389/devops-training-java:${env.BUILD_NUMBER}"
                        sh "docker push manir1389/devops-training-java:tagname" // Push as 'latest' as well
                    }
                }
            }
        }
    }
}
